#: common/gdm-common.c:324
msgid "/dev/urandom is not a character device"
msgstr "/dev/urandom이 캐릭터 장치가 아닙니다"

#: common/gdm-common.c:358
msgid "Unable to create transient display: "
msgstr "임시 디스플레이를 만들 수 없습니다: "

#: common/gdm-common.c:555
msgid "Could not identify the current session: "
msgstr "현재 세션을 구별할 수 없습니다: "

#: common/gdm-common.c:564
msgid "Could not identify the current seat."
msgstr "현재 자리를 구별할 수 없습니다."

#: daemon/gdm-manager.c:668 daemon/gdm-manager.c:704
msgid "No display available"
msgstr "디스플레이가 없습니다"

#: daemon/gdm-manager.c:754 daemon/gdm-manager.c:1059
msgid "No session available"
msgstr "세션이 없습니다"

#: daemon/gdm-manager.c:770
msgid "Can only be called before user is logged in"
msgstr "사용자가 로그인하기 전에만 부를 수 있습니다"

#: daemon/gdm-manager.c:782
msgid "Caller not GDM"
msgstr "GDM에서 호출하지 않았습니다"

#: daemon/gdm-manager.c:792
msgid "Unable to open private communication channel"
msgstr "안전한 통신 채널을 열 수 없습니다"

#: daemon/gdm-session-auditor.c:88
msgid "Username"
msgstr "사용자 이름"

#: daemon/gdm-session-auditor.c:89
msgid "The username"
msgstr "사용자 이름"

#: daemon/gdm-session-auditor.c:93
msgid "Hostname"
msgstr "호스트 이름"

#: daemon/gdm-session-auditor.c:94
msgid "The hostname"
msgstr "호스트 이름"

#: daemon/gdm-session-auditor.c:99
msgid "Display Device"
msgstr "디스플레이 장치"

#: daemon/gdm-session-auditor.c:100
msgid "The display device"
msgstr "디스플레이 장치"

#: daemon/gdm-session.c:1442
msgid "Could not create authentication helper process"
msgstr "인증 도우미 프로세스를 만들지 못했습니다"

#: daemon/gdm-session-worker.c:807
msgid ""
"You reached the maximum password authentication attempts, please try another "
"method"
msgstr "암호 인증 시도 최대 제한에 도달했습니다. 다른 방법을 시도해 보십시오"

#: daemon/gdm-session-worker.c:810
msgid ""
"You reached the maximum auto login attempts, please try another "
"authentication method"
msgstr "자동 로그인 시도 최대 제한에 도달했습니다. 다른 방법을 시도해 보십시오"

#: daemon/gdm-session-worker.c:813
msgid ""
"You reached the maximum fingerprint authentication attempts, please try "
"another method"
msgstr "지문 인증 시도 최대 제한에 도달했습니다. 다른 방법을 시도해 보십시오"

#: daemon/gdm-session-worker.c:816
msgid ""
"You reached the maximum smart card authentication attempts, please try "
"another method"
msgstr ""
"스마트 카드 인증 시도 최대 제한에 도달했습니다. 다른 방법을 시도해 보십시오"

#: daemon/gdm-session-worker.c:818
msgid ""
"You reached the maximum authentication attempts, please try another method"
msgstr "인증 시도 최대 제한에 도달했습니다. 다른 방법을 시도해 보십시오"

#: daemon/gdm-session-worker.c:825
msgid "Sorry, password authentication didn’t work. Please try again."
msgstr "죄송합니다. 암호 인증이 동작하지 않았습니다. 다시 시도하십시오."

#: daemon/gdm-session-worker.c:828
msgid "Sorry, auto login didn’t work. Please try again."
msgstr "죄송합니다. 자동 로그인이 동작하지 않았습니다. 다시 시도하십시오."

#: daemon/gdm-session-worker.c:831
msgid "Sorry, fingerprint authentication didn’t work. Please try again."
msgstr "죄송합니다. 지문 인증이 동작하지 않았습니다. 다시 시도하십시오."

#: daemon/gdm-session-worker.c:834
msgid "Sorry, smart card authentication didn’t work. Please try again."
msgstr "죄송합니다. 스마트 카드 인증이 동작하지 않습니다. 다시 시도하십시오."

#: daemon/gdm-session-worker.c:836
msgid "Sorry, that didn’t work. Please try again."
msgstr "죄송합니다. 동작하지 않았습니다. 다시 시도하십시오."

#: daemon/gdm-session-worker.c:851
msgid "Your account was given a time limit that’s now passed."
msgstr "계정에 시간 제한이 걸려 있었고, 지금 그 제한이 지났습니다."

#: daemon/gdm-session-worker.c:1208
msgid "Username:"
msgstr "사용자 이름:"

#: daemon/gdm-session-worker.c:1625 daemon/gdm-session-worker.c:1642
msgid "no user account available"
msgstr "사용자 계정이 없습니다"

#: daemon/gdm-session-worker.c:1669
msgid "Unable to change to user"
msgstr "다른 사용자로 바꿀 수 없습니다"

#: daemon/gdm-wayland-session.c:513
msgid "GNOME Display Manager Wayland Session Launcher"
msgstr "그놈 디스플레이 관리자 웨일랜드 세션 실행"

#: daemon/main.c:124 daemon/main.c:137
#, c-format
msgid "Cannot write PID file %s: possibly out of disk space: %s"
msgstr "PID 파일 %s에 쓸 수 없습니다: 디스크 공간이 부족한 것 같습니다: %s"

#: daemon/main.c:222
msgid "Make all warnings fatal"
msgstr "모든 경고를 치명적인 것으로 취급합니다"

#: daemon/main.c:223
msgid "Exit after a time (for debugging)"
msgstr "일정 시간이 지나면 끝납니다(디버깅용)"

#: daemon/main.c:224
msgid "Print GDM version"
msgstr "GDM 버전을 표시합니다"

#: daemon/main.c:235
msgid "GNOME Display Manager"
msgstr "그놈 디스플레이 관리자"

#. make sure the pid file doesn't get wiped
#: daemon/main.c:255
msgid "Only the root user can run GDM"
msgstr "루트만 GDM을 실행합니다"

#. Translators: worker is a helper process that does the work
#. of starting up a session
#: daemon/session-worker-main.c:127
msgid "GNOME Display Manager Session Worker"
msgstr "그놈 디스플레이 관리자 세션 워커"

#: data/gnome-greeter.desktop.in:2
msgid "GNOME Greeter"
msgstr "그놈 안내"

#: data/gnome-greeter.desktop.in:3
msgid "The default GNOME Greeter session"
msgstr "기본 그놈 안내 세션"

#: data/gnome-initial-setup.desktop.in:2
msgid "GNOME Initial Setup"
msgstr "그놈 초기 설정"

#: data/gnome-initial-setup.desktop.in:3
msgid "The GNOME Initial Setup session"
msgstr "그놈 초기 설정 세션"

#: data/org.gnome.displaymanager.policy:11
msgid "Allow managing user sessions"
msgstr "사용자 세션 관리 허용"

#: data/org.gnome.displaymanager.policy:12
msgid "Authentication is required to start or stop a user session"
msgstr "사용자 세션을 시작하거나 중지하려면 인증이 필요합니다"

#: data/org.gnome.login-screen.gschema.xml:11
msgid "Whether or not to allow switchable authentication for login"
msgstr "로그인 할 때 전환 가능한 인증 허용 여부"

#: data/org.gnome.login-screen.gschema.xml:14
msgid ""
"The login screen can optionally allow a single PAM service to provide "
"multiple authentication mechanisms via a GDM PAM."
msgstr ""
"로그인 화면에서 단일 PAM 서비스가 GDM PAM을 통해 여러 인증 메커니즘을 제공할 "
"수 있도록 선택적으로 허용할 수 있습니다."

#: data/org.gnome.login-screen.gschema.xml:21
msgid "Whether or not to allow authentication via external web site"
msgstr "외부 웹사이트를 통한 인증 허용 여부"

#: data/org.gnome.login-screen.gschema.xml:24
msgid ""
"The login screen can optionally allow users to authenticate via web login."
msgstr ""
"로그인 화면에서 사용자가 웹 로그인을 통해 인증할 수 있도록 선택적으로 허용할 "
"수 있습니다."

#: data/org.gnome.login-screen.gschema.xml:31
msgid "Whether or not to allow authentication using a passkey"
msgstr "패스키를 사용한 인증 허용 여부"

#: data/org.gnome.login-screen.gschema.xml:34
msgid ""
"The login screen can optionally allow users who have passkeys to log in "
"using those passkeys."
msgstr ""
"로그인 화면에서 패스키를 보유한 사용자가 해당 패스키를 사용하여 로그인할 수 "
"있도록 선택적으로 허용할 수 있습니다."

#: data/org.gnome.login-screen.gschema.xml:41
msgid "Whether or not to allow fingerprint readers for login"
msgstr "로그인에 지문 인식 장치 사용을 허용할지 여부"

#: data/org.gnome.login-screen.gschema.xml:44
msgid ""
"The login screen can optionally allow users who have enrolled their "
"fingerprints to log in using those prints."
msgstr "로그인 화면에서 지문을 등록한 사용자는 지문으로 로그인을 허용합니다."

#: data/org.gnome.login-screen.gschema.xml:51
msgid "Whether or not to allow smartcard readers for login"
msgstr "로그인에 스마트카드 리더를 허용할지 여부"

#: data/org.gnome.login-screen.gschema.xml:54
msgid ""
"The login screen can optionally allow users who have smartcards to log in "
"using those smartcards."
msgstr ""
"로그인 화면에서 스마트카드가 있는 사용자는 스마트카드로 로그인을 허용합니다."

#: data/org.gnome.login-screen.gschema.xml:61
msgid "Whether or not to allow passwords for login"
msgstr "로그인에 암호를 허용할지 여부"

#: data/org.gnome.login-screen.gschema.xml:64
msgid ""
"The login screen can be configured to disallow password authentication, "
"forcing the user to use smartcard or fingerprint authentication."
msgstr ""
"암호 인증을 거부하도록 로그인 화면을 설정할 수 있습니다. 그렇게 하면 사용자"
"는 스마트 카드나 지문 인증을 해야 합니다."

#: data/org.gnome.login-screen.gschema.xml:71
#: data/org.gnome.login-screen.gschema.xml:81
msgid "Path to small image at top of user list"
msgstr "사용자 목록 위의 작은 그림에 대한 경로"

#: data/org.gnome.login-screen.gschema.xml:74
msgid ""
"The login screen can optionally show a small image to provide site "
"administrators and distributions a way to display branding."
msgstr ""
"로그인 화면에서 작은 이미지를 표시해, 시스템 관리자나 운영 체제 배포판 측에"
"서 브랜드를 표시합니다."

#: data/org.gnome.login-screen.gschema.xml:84
msgid ""
"The fallback login screen can optionally show a small image to provide site "
"administrators and distributions a way to display branding."
msgstr ""
"대체 모드 로그인 화면에서 작은 이미지를 표시해, 시스템 관리자나 운영 체제 배"
"포판 측에서 브랜드를 표시합니다."

#: data/org.gnome.login-screen.gschema.xml:91
msgid "Avoid showing user list"
msgstr "사용자 목록 표시하지 않기"

#: data/org.gnome.login-screen.gschema.xml:94
msgid ""
"The login screen normally shows a list of available users to log in as. This "
"setting can be toggled to disable showing the user list."
msgstr ""
"로그인 화면은 로그인할 수 있는 사용자 목록을 표시합니다. 이 설정을 바꾸면 이 "
"사용자 목록을 표시하지 않습니다."

#: data/org.gnome.login-screen.gschema.xml:101
msgid "Enable showing the banner message"
msgstr "배너 메시지 사용"

#: data/org.gnome.login-screen.gschema.xml:104
msgid "Set to true to show the banner message text."
msgstr "참이면 배너 글을 표시합니다."

#: data/org.gnome.login-screen.gschema.xml:110
msgid "Banner message source"
msgstr "배너 글의 출처"

#: data/org.gnome.login-screen.gschema.xml:113
msgid "The source of the text banner message on the login screen."
msgstr "로그인 창에 표시할 배너 글의 출처."

#: data/org.gnome.login-screen.gschema.xml:119
msgid "Banner message text"
msgstr "배너 글"

#: data/org.gnome.login-screen.gschema.xml:122
msgid "Text banner message to show in the login window."
msgstr "로그인 창에 표시할 배너 글."

#: data/org.gnome.login-screen.gschema.xml:128
msgid "Banner message path"
msgstr "배너 글의 경로"

#: data/org.gnome.login-screen.gschema.xml:131
msgid "Path to text file with banner message to show in the login window."
msgstr "로그인 창에 표시할 배너 글 파일의 경로."

#: data/org.gnome.login-screen.gschema.xml:137
msgid "Disable showing the restart buttons"
msgstr "다시 시작 단추를 표시하지 않음"

#: data/org.gnome.login-screen.gschema.xml:140
msgid "Set to true to disable showing the restart buttons in the login window."
msgstr "참이면 로그인 창에 다시 시작 단추를 표시하지 않습니다."

#: data/org.gnome.login-screen.gschema.xml:146
msgid "Number of allowed authentication failures"
msgstr "허용하는 최대 인증 실패 개수"

#: data/org.gnome.login-screen.gschema.xml:149
msgid ""
"The number of times a user is allowed to attempt authentication, before "
"giving up and going back to user selection."
msgstr ""
"한 사용자가 인증을 시도하는 게 허용된 최대 횟수. 넘어가면 사용자 선택으로 돌"
"아갑니다."

#: utils/gdm-config.c:117
msgid "Show command help"
msgstr "명령 도움말 표시"

#: utils/gdm-config.c:121
msgid "Show verbose output"
msgstr "자세한 출력 표시"

#: utils/gdm-config.c:125
msgid "Show debug output"
msgstr "디버그 출력 표시"

#: utils/gdm-config.c:134
msgid "Enable the authentication method"
msgstr "인증 방법 사용"

#: utils/gdm-config.c:138
msgid "Disable the authentication method"
msgstr "인증 방법 비활성화"

#: utils/gdm-config.c:147
msgid "Require the authentication method"
msgstr "인증 방법 필요"

#: utils/gdm-config.c:151
msgid "Action to perform on smartcard removal"
msgstr "스마트 카드 제거 시 수행할 동작"

#: utils/gdm-config.c:160
msgid "Assume yes to any answer"
msgstr "모든 답변에 예라고 가정합니다"

#: utils/gdm-config.c:262
msgid "Configure Password Authentication."
msgstr "암호 인증을 구성합니다."

#: utils/gdm-config.c:264
msgid "Configure Fingerprint Authentication."
msgstr "지문 인증을 구성합니다."

#: utils/gdm-config.c:266
msgid "Configure Smart Card Authentication."
msgstr "스마트 카드 인증을 구성합니다."

#: utils/gdm-config.c:268
msgid "Reset the GDM Authentication configuration."
msgstr "GDM 인증 구성을 재설정합니다."

#: utils/gdm-config.c:270
msgid "Show GDM Authentication configuration."
msgstr "GDM 인증 구성을 표시합니다."

#: utils/gdm-config.c:281
msgid "Password options"
msgstr "암호 옵션"

#: utils/gdm-config.c:283
msgid "Fingerprint options"
msgstr "지문 옵션"

#: utils/gdm-config.c:285
msgid "Smart Card options"
msgstr "스마트 카드 옵션"

#: utils/gdm-config.c:287
msgid "Reset options"
msgstr "재설정 옵션"

#: utils/gdm-config.c:289
msgid "Show options"
msgstr "옵션 보기"

#: utils/gdm-config.c:319
msgid "No PAM module available for Password authentication"
msgstr "암호 인증에 사용할 수 있는 PAM 모듈이 없습니다"

#: utils/gdm-config.c:321
msgid "No PAM module available for Smart Card authentication"
msgstr "스마트 카드 인증에 사용할 수 있는 PAM 모듈이 없습니다"

#: utils/gdm-config.c:323
msgid "No PAM module available for Fingerprint authentication"
msgstr "지문 인증에 사용할 수 있는 PAM 모듈이 없습니다"

#: utils/gdm-config.c:354
#, c-format
msgid "“%s” needs at least one parameter"
msgstr "“%s”에 하나 이상의 매개 변수가 필요합니다"

#. TRANSLATORS: “command” can't be enabled...
#: utils/gdm-config.c:363
#, c-format
msgid "“%s” can't be enabled and disabled at the same time"
msgstr "“%s” 은(는) 동시에 활성화 및 비활성화할 수 없습니다"

#. TRANSLATORS: option is not a valid command “option-key” value
#: utils/gdm-config.c:386
#, c-format
msgid "“%s” is not a valid %s “%s” value"
msgstr "“%s”은(는) 유효한 %s “%s” 값이 아닙니다"

#: utils/gdm-config.c:633
msgid "No distro detected, no hook to run"
msgstr "배포판을 감지할 수 없으며 실행할 후크가 없습니다"

#: utils/gdm-config.c:651
#, c-format
msgid "No valid args found to run hook “%s”"
msgstr "“%s” 후크를 실행하는 데 유효한 인수가 없습니다"

#: utils/gdm-config.c:656
#, c-format
msgid "Running distro hook “%s”\n"
msgstr "“%s” 배포판 후크 실행\n"

#: utils/gdm-config.c:670
#, c-format
msgid "Distro hook “%s” requested stopping"
msgstr "“%s” 배포판 후크가 중지를 요청했습니다"

#: utils/gdm-config.c:683
#, c-format
msgid ""
"Distro hook failed with exit status %d and error %s:\n"
"Standard output:\n"
"%s\n"
"Error output:\n"
"%s"
msgstr ""
"종료 상태 %d 및 오류 %s로 인해 배포판 후크가 실패했습니다:\n"
"표준 출력:\n"
"%s\n"
"오류 출력:\n"
"%s"

#. TRANSLATORS: Failed to set command “command” option key “option-key” via distro hook
#: utils/gdm-config.c:733
#, c-format
msgid "Failed to set command “%s” option key “%s” via distro hook: "
msgstr "배포판 후크를 통해 명령어 “%s” 옵션 키 “%s” 설정에 실패했습니다: "

#: utils/gdm-config.c:773
#, c-format
msgid "Failed to create directory %s"
msgstr "%s 디렉터리를 만드는데 실패했습니다"

#: utils/gdm-config.c:844
msgid "dconf profile not found"
msgstr "dconf 프로필을 찾을 수 없습니다"

#: utils/gdm-config.c:934
msgid "dconf has no system-db configured"
msgstr "dconf에 system-db가 구성되지 않았습니다"

#. TRANSLATORS: First value is a file path, second is an error message
#: utils/gdm-config.c:1083

msgstr "تعذَّر إنشاء مجلد LogDir %s: %s"

#: daemon/main.c:223
#, c-format
msgid "Can’t find the GDM user “%s”. Aborting!"
msgstr "لم أجد مستخدم مدير عرض جنوم «%s». سأجهض العملية!"


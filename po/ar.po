#: daemon/gdm-session.c:1444
msgid "Could not create authentication helper process"
msgstr "تعذَّر إنشاء عملية مساعد الاستيثاق"

#: daemon/gdm-session-worker.c:813
msgid ""
"You reached the maximum password authentication attempts, please try another "
"method"
msgstr "بلغت الحد الأقصى لمحاولات الاستيثاق بكلمة السر، جرِّب طريقة أخرى"

#: daemon/gdm-session-worker.c:816
msgid ""
"You reached the maximum auto login attempts, please try another authentication "
"method"
msgstr "بلغت الحد الأقصى لمحاولات الولوج الآلي، جرِّب طريقة استيثاق أخرى"

#: daemon/gdm-session-worker.c:819
msgid ""
"You reached the maximum fingerprint authentication attempts, please try another "
"method"
msgstr "بلغت الحد الأقصى لمحاولات الاستيثاق بالبصمة، جرِّب طريقة أخرى"

#: daemon/gdm-session-worker.c:822
msgid ""
"You reached the maximum smart card authentication attempts, please try another "
"method"
msgstr "بلغت الحد الأقصى لمحاولات الاستيثاق بالبطاقة الذكية، جرِّب طريقة أخرى"

#: daemon/gdm-session-worker.c:824
msgid "You reached the maximum authentication attempts, please try another method"
msgstr "بلغت الحد الأقصى لمحاولات الاستيثاق، جرِّب طريقة أخرى"

#: daemon/gdm-session-worker.c:831
msgid "Sorry, password authentication didn’t work. Please try again."
msgstr "لم ينجح الاستيثاق بكلمة السر، أعِد المحاولة."

#: daemon/gdm-session-worker.c:834
msgid "Sorry, auto login didn’t work. Please try again."
msgstr "لم ينجح الولوج الآلي، أعِد المحاولة."

#: daemon/gdm-session-worker.c:837
msgid "Sorry, fingerprint authentication didn’t work. Please try again."
msgstr "لم ينجح الاستيثاق بالبصمة، أعِد المحاولة."

#: daemon/gdm-session-worker.c:840
msgid "Sorry, smart card authentication didn’t work. Please try again."
msgstr "لم ينجح الاستيثاق بالبطاقة الذكية، أعِد المحاولة."

#: daemon/gdm-session-worker.c:842
msgid "Sorry, that didn’t work. Please try again."
msgstr "لم يُفلح هذا، أعِد المحاولة."

#: daemon/gdm-session-worker.c:857
msgid "Your account was given a time limit that’s now passed."
msgstr "انقضت المدة الزمنية الممنوحة لحسابك."


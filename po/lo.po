#: chooser/gdm-host-chooser-dialog.c:139
msgid "_Refresh"
msgstr "_ໂຫຼດໃໝ່"

#: chooser/gdm-host-chooser-dialog.c:140
msgid "_Cancel"
msgstr "_ຍົກເລີກ"

#: chooser/gdm-host-chooser-dialog.c:141
msgid "C_onnect"
msgstr "_ເຊື່ອມຕໍ່"

#: chooser/gdm-host-chooser-dialog.c:146
msgid "Select System"
msgstr "ເລືອກລະບົບ"

#: chooser/gdm-host-chooser-widget.c:255
msgid "XDMCP: Could not create XDMCP buffer!"
msgstr "XDMCP: ບໍ່ສາມາດສ້າງບັຟເຟີ XDMCP ໄດ້!"

#: chooser/gdm-host-chooser-widget.c:261
msgid "XDMCP: Could not read XDMCP header!"
msgstr "XDMCP: ບໍ່ສາມາດອ່ານສ່ວນຫົວ XDMCP ໄດ້!"

#: chooser/gdm-host-chooser-widget.c:267
msgid "XDMCP: Incorrect XDMCP version!"
msgstr "XDMCP: ເວີຊັນ XDMCP ບໍ່ຖືກຕ້ອງ!"

#: chooser/gdm-host-chooser-widget.c:273
msgid "XDMCP: Unable to parse address"
msgstr "XDMCP: ບໍ່ສາມາດວິເຄາະທີ່ຢູ່ໄດ້"

#: common/gdm-common.c:343
#, c-format
msgid "/dev/urandom is not a character device"
msgstr "/dev/urandom ບໍ່ແມ່ນອຸປະກອນຕົວອັກສອນ"

#: common/gdm-common.c:382
msgid "Unable to create transient display: "
msgstr "ບໍ່ສາມາດສ້າງການສະແດງຜົນຊົ່ວຄາວໄດ້: "

#: common/gdm-common.c:579
msgid "Could not identify the current session: "
msgstr "ບໍ່ສາມາດລະບຸເຊດຊັນປັດຈຸບັນໄດ້: "

#: common/gdm-common.c:588
#, c-format
msgid "Could not identify the current seat."
msgstr "ບໍ່ສາມາດລະບຸ seat ປັດຈຸບັນໄດ້."

#: daemon/gdm-display-access-file.c:280 daemon/gdm-display-access-file.c:301
#, c-format
msgid "Could not find user “%s” on system"
msgstr "ບໍ່ພົບຜູ້ໃຊ້ “%s” ໃນລະບົບ"

#: daemon/gdm-legacy-display.c:226
msgid ""
"Could not start the X server (your graphical environment) due to an internal "
"error. Please contact your system administrator or check your syslog to "
"diagnose. In the meantime this display will be disabled.  Please restart GDM "
"when the problem is corrected."
msgstr "ບໍ່ສາມາດເລີ່ມ X server (ສະພາບແວດລ້ອມກຣາຟິກຂອງທ່ານ) ໄດ້ ເນື່ອງຈາກຄວາມຜິດພາດພາຍໃນ. ກະລຸນາຕິດຕໍ່ຜູ້ເບິ່ງແຍງລະບົບຂອງທ່ານ ຫຼືກວດສອບ syslog ເພື່ອວິນິດໄສ. ໃນລະຫວ່າງນີ້, ການສະແດງຜົນນີ້ຈະຖືກປິດໃຊ້ງານ. ກະລຸນາຣີສະຕາດ GDM ເມື່ອບັນຫາໄດ້ຮັບການແກ້ໄຂແລ້ວ."

#: daemon/gdm-manager.c:765
msgid "No display available"
msgstr "ບໍ່ມີການສະແດງຜົນທີ່ໃຊ້ງານໄດ້"

#: daemon/gdm-manager.c:863 daemon/gdm-manager.c:1192
msgid "No session available"
msgstr "ບໍ່ມີເຊດຊັນທີ່ໃຊ້ງານໄດ້"

#: daemon/gdm-manager.c:882
msgid "Chooser session unavailable"
msgstr "ເຊດຊັນໂຕເລືອກບໍ່ສາມາດໃຊ້ງານໄດ້"

#: daemon/gdm-manager.c:898
msgid "Can only be called before user is logged in"
msgstr "ສາມາດເອີ້ນໃຊ້ໄດ້ກ່ອນທີ່ຜູ້ໃຊ້ຈະລັອກອິນເທົ່ານັ້ນ"

#: daemon/gdm-manager.c:910
msgid "Caller not GDM"
msgstr "ໂຕເອີ້ນໃຊ້ບໍ່ແມ່ນ GDM"

#: daemon/gdm-manager.c:920
msgid "Unable to open private communication channel"
msgstr "ບໍ່ສາມາດເປີດຊ່ອງທາງການສື່ສານສ່ວນຕົວໄດ້"

#: daemon/gdm-server.c:387
#, c-format
msgid "Server was to be spawned by user %s but that user doesn’t exist"
msgstr "ເຊີບເວີຈະຖືກສ້າງໂດຍຜູ້ໃຊ້ %s ແຕ່ຜູ້ໃຊ້ນັ້ນບໍ່ມີຢູ່"

#: daemon/gdm-server.c:398 daemon/gdm-server.c:418
#, c-format
msgid "Couldn’t set groupid to %d"
msgstr "ບໍ່ສາມາດກຳນົດ groupid ເປັນ %d ໄດ້"

#: daemon/gdm-server.c:404
#, c-format
msgid "initgroups () failed for %s"
msgstr "initgroups () ລົ້ມເຫຼວສຳລັບ %s"

#: daemon/gdm-server.c:410
#, c-format
msgid "Couldn’t set userid to %d"
msgstr "ບໍ່ສາມາດກຳນົດ userid ເປັນ %d ໄດ້"

#: daemon/gdm-server.c:482
#, c-format
msgid "%s: Could not open log file for display %s!"
msgstr "%s: ບໍ່ສາມາດເປີດໄຟລ໌ບັນທຶກສຳລັບການສະແດງຜົນ %s ໄດ້!"

#: daemon/gdm-server.c:503 daemon/gdm-server.c:509 daemon/gdm-server.c:515
#, c-format
msgid "%s: Error setting %s to %s"
msgstr "%s: ຜິດພາດໃນການຕັ້ງຄ່າ %s ເປັນ %s"

#: daemon/gdm-server.c:535
#, c-format
msgid "%s: Server priority couldn’t be set to %d: %s"
msgstr "%s: ບໍ່ສາມາດຕັ້ງຄ່າຄວາມສຳຄັນຂອງເຊີບເວີເປັນ %d ໄດ້: %s"

#: daemon/gdm-server.c:690
#, c-format
msgid "%s: Empty server command for display %s"
msgstr "%s: ຄຳສັ່ງເຊີບເວີວ່າງເປົ່າສຳລັບການສະແດງຜົນ %s"

#: daemon/gdm-session-auditor.c:88
msgid "Username"
msgstr "ຊື່ຜູ້ໃຊ້"

#: daemon/gdm-session-auditor.c:89
msgid "The username"
msgstr "ຊື່ຜູ້ໃຊ້"

#: daemon/gdm-session-auditor.c:93
msgid "Hostname"
msgstr "ຊື່ໂຮສ"

#: daemon/gdm-session-auditor.c:94
msgid "The hostname"
msgstr "ຊື່ໂຮສ"

#: daemon/gdm-session-auditor.c:99
msgid "Display Device"
msgstr "ອຸປະກອນສະແດງຜົນ"

#: daemon/gdm-session-auditor.c:100
msgid "The display device"
msgstr "ອຸປະກອນສະແດງຜົນ"

#: daemon/gdm-session.c:1444
msgid "Could not create authentication helper process"
msgstr "ບໍ່ສາມາດສ້າງໂພຣເຊສໂຕຊ່ວຍຢືນຢັນຕົວຕົນໄດ້"

#: daemon/gdm-session-worker.c:813
msgid ""
"You reached the maximum password authentication attempts, please try another "
"method"
msgstr "ທ່ານພະຍາຍາມຢືນຢັນຕົວຕົນດ້ວຍລະຫັດຜ່ານຄົບຈຳນວນຄັ້ງສູງສຸດແລ້ວ, ກະລຸນາລອງວິທີອື່ນ"

#: daemon/gdm-session-worker.c:816
msgid ""
"You reached the maximum auto login attempts, please try another "
"authentication method"
msgstr "ທ່ານພະຍາຍາມລັອກອິນອັດຕະໂນມັດຄົບຈຳນວນຄັ້ງສູງສຸດແລ້ວ, ກະລຸນາລອງວິທີຢືນຢັນຕົວຕົນແບບອື່ນ"

#: daemon/gdm-session-worker.c:819
msgid ""
"You reached the maximum fingerprint authentication attempts, please try "
"another method"
msgstr "ທ່ານພະຍາຍາມຢືນຢັນຕົວຕົນດ້ວຍລາຍນິ້ວມືຄົບຈຳນວນຄັ້ງສູງສຸດແລ້ວ, ກະລຸນາລອງວິທີອື່ນ"

#: daemon/gdm-session-worker.c:822
msgid ""
"You reached the maximum smart card authentication attempts, please try "
"another method"
msgstr "ທ່ານພະຍາຍາມຢືນຢັນຕົວຕົນດ້ວຍສະມາດກາດຄົບຈຳນວນຄັ້ງສູງສຸດແລ້ວ, ກະລຸນາລອງວິທີອື່ນ"

#: daemon/gdm-session-worker.c:824
msgid ""
"You reached the maximum authentication attempts, please try another method"
msgstr "ທ່ານພະຍາຍາມຢືນຢັນຕົວຕົນຄົບຈຳນວນຄັ້ງສູງສຸດແລ້ວ, ກະລຸນາລອງວິທີອື່ນ"

#: daemon/gdm-session-worker.c:831
msgid "Sorry, password authentication didn’t work. Please try again."
msgstr "ຂໍອະໄພ, ການຢືນຢັນຕົວຕົນດ້ວຍລະຫັດຜ່ານບໍ່ສຳເລັດ. ກະລຸນາລອງໃໝ່ອີກຄັ້ງ."

#: daemon/gdm-session-worker.c:834
msgid "Sorry, auto login didn’t work. Please try again."
msgstr "ຂໍອະໄພ, ການລັອກອິນອັດຕະໂນມັດບໍ່ສຳເລັດ. ກະລຸນາລອງໃໝ່ອີກຄັ້ງ."

#: daemon/gdm-session-worker.c:837
msgid "Sorry, fingerprint authentication didn’t work. Please try again."
msgstr "ຂໍອະໄພ, ການຢືນຢັນຕົວຕົນດ້ວຍລາຍນິ້ວມືບໍ່ສຳເລັດ. ກະລຸນາລອງໃໝ່ອີກຄັ້ງ."

#: daemon/gdm-session-worker.c:840
msgid "Sorry, smart card authentication didn’t work. Please try again."
msgstr "ຂໍອະໄພ, ການຢືນຢັນຕົວຕົນດ້ວຍສະມາດກາດບໍ່ສຳເລັດ. ກະລຸນາລອງໃໝ່ອີກຄັ້ງ."

#: daemon/gdm-session-worker.c:842
msgid "Sorry, that didn’t work. Please try again."
msgstr "ຂໍອະໄພ, ການດຳເນີນການບໍ່ສຳເລັດ. ກະລຸນາລອງໃໝ່ອີກຄັ້ງ."

#: daemon/gdm-session-worker.c:857
msgid "Your account was given a time limit that’s now passed."
msgstr "ບັນຊີຂອງທ່ານຖືກຈຳກັດເວລາໃຊ້ງານ ແລະ ຕອນນີ້ໝົດກຳນົດແລ້ວ."

#: daemon/gdm-session-worker.c:1258
msgid "Username:"
msgstr "ຊື່ຜູ້ໃຊ້:"

#: daemon/gdm-session-worker.c:1675 daemon/gdm-session-worker.c:1692
#, c-format
msgid "no user account available"
msgstr "ບໍ່ມີບັນຊີຜູ້ໃຊ້ທີ່ໃຊ້ງານໄດ້"

#: daemon/gdm-session-worker.c:1719
msgid "Unable to change to user"
msgstr "ບໍ່ສາມາດປ່ຽນເປັນຜູ້ໃຊ້ອື່ນໄດ້"

#: daemon/gdm-wayland-session.c:531
msgid "GNOME Display Manager Wayland Session Launcher"
msgstr "ໂຕເປີດເຊດຊັນ Wayland ຂອງ GNOME Display Manager"

#: daemon/gdm-xdmcp-display-factory.c:614
msgid "Could not create socket!"
msgstr "ບໍ່ສາມາດສ້າງ socket ໄດ້!"

#: daemon/gdm-x-session.c:882
msgid "Run program through /etc/gdm/Xsession wrapper script"
msgstr "ລັນໂປຣແກຣມຜ່ານສະຄຣິບຫໍ່ຫຸ້ມ /etc/gdm/Xsession"

#: daemon/gdm-x-session.c:883
msgid "Listen on TCP socket"
msgstr "ຮັບຟັງເທິງ TCP socket"

#: daemon/gdm-x-session.c:895
msgid "GNOME Display Manager X Session Launcher"
msgstr "ໂຕເປີດເຊດຊັນ X ຂອງ GNOME Display Manager"

#: daemon/main.c:126 daemon/main.c:139
#, c-format
msgid "Cannot write PID file %s: possibly out of disk space: %s"
msgstr "ບໍ່ສາມາດຂຽນໄຟລ໌ PID %s ໄດ້: ອາດເນື່ອງມາຈາກພື້ນທີ່ດິສກ໌ເຕັມ: %s"

#: daemon/main.c:197
#, c-format
msgid "Can’t find the GDM user “%s”. Aborting!"
msgstr "ບໍ່ພົບຜູ້ໃຊ້ GDM “%s”. ກຳລັງຍົກເລີກ!"

#: daemon/main.c:203
msgid "The GDM user should not be root. Aborting!"
msgstr "ຜູ້ໃຊ້ GDM ບໍ່ຄວນເປັນ root. ກຳລັງຍົກເລີກ!"

#: daemon/main.c:209
#, c-format
msgid "Can’t find the GDM group “%s”. Aborting!"
msgstr "ບໍ່ພົບກຸ່ມ GDM “%s”. ກຳລັງຍົກເລີກ!"

#: daemon/main.c:215
msgid "The GDM group should not be root. Aborting!"
msgstr "ກຸ່ມ GDM ບໍ່ຄວນເປັນ root. ກຳລັງຍົກເລີກ!"

#: daemon/main.c:283
msgid "Make all warnings fatal"
msgstr "ເຮັດໃຫ້ຄຳເຕືອນທັງໝົດເປັນຄວາມຜິດພາດຮ້າຍແຮງ"

#: daemon/main.c:284
msgid "Exit after a time (for debugging)"
msgstr "ອອກຈາກໂປຣແກຣມຫຼັງຈາກໄລຍະເວລາໜຶ່ງ (ສຳລັບການດີບັກ)"

#: daemon/main.c:285
msgid "Print GDM version"
msgstr "ພິມເວີຊັນຂອງ GDM"

#: daemon/main.c:296
msgid "GNOME Display Manager"
msgstr "ຕົວຈັດການການສະແດງຜົນ GNOME"

#. make sure the pid file doesn't get wiped
#: daemon/main.c:316
msgid "Only the root user can run GDM"
msgstr "ສະເພາະຜູ້ໃຊ້ root ເທົ່ານັ້ນທີ່ສາມາດລັນ GDM ໄດ້"

#. Translators: worker is a helper process that does the work
#. of starting up a session
#: daemon/session-worker-main.c:127
msgid "GNOME Display Manager Session Worker"
msgstr "ໂຕເຮັດວຽກເຊດຊັນຂອງຕົວຈັດການການສະແດງຜົນ GNOME"

#: data/org.gnome.login-screen.gschema.xml:11
msgid "Whether or not to allow fingerprint readers for login"
msgstr "ອະນຸຍາດໃຫ້ໃຊ້ເຄື່ອງອ່ານລາຍນິ້ວມືສຳລັບການລັອກອິນ ຫຼືບໍ່"

#: data/org.gnome.login-screen.gschema.xml:14
msgid ""
"The login screen can optionally allow users who have enrolled their "
"fingerprints to log in using those prints."
msgstr "ໜ້າຈໍລັອກອິນສາມາດເລືອກທີ່ຈະອະນຸຍາດໃຫ້ຜູ້ໃຊ້ທີ່ໄດ້ລົງທະບຽນລາຍນິ້ວມືໄວ້ ສາມາດລັອກອິນໂດຍໃຊ້ລາຍນິ້ວມືເຫຼົ່ານັ້ນໄດ້."

#: data/org.gnome.login-screen.gschema.xml:21
msgid "Whether or not to allow smartcard readers for login"
msgstr "ອະນຸຍາດໃຫ້ໃຊ້ເຄື່ອງອ່ານສະມາດກາດສຳລັບການລັອກອິນ ຫຼືບໍ່"

#: data/org.gnome.login-screen.gschema.xml:24
msgid ""
"The login screen can optionally allow users who have smartcards to log in "
"using those smartcards."
msgstr "ໜ້າຈໍລັອກອິນສາມາດເລືອກທີ່ຈະອະນຸຍາດໃຫ້ຜູ້ໃຊ້ທີ່ມີສະມາດກາດ ສາມາດລັອກອິນໂດຍໃຊ້ສະມາດກາດເຫຼົ່ານັ້ນໄດ້."

#: data/org.gnome.login-screen.gschema.xml:31
msgid "Whether or not to allow passwords for login"
msgstr "ອະນຸຍາດໃຫ້ໃຊ້ລະຫັດຜ່ານສຳລັບການລັອກອິນ ຫຼືບໍ່"

#: data/org.gnome.login-screen.gschema.xml:34
msgid ""
"The login screen can be configured to disallow password authentication, "
"forcing the user to use smartcard or fingerprint authentication."
msgstr "ໜ້າຈໍລັອກອິນສາມາດຖືກກຳນົດຄ່າໃຫ້ບໍ່ອະນຸຍາດການຢືນຢັນຕົວຕົນດ້ວຍລະຫັດຜ່ານ, ບັງຄັບໃຫ້ຜູ້ໃຊ້ຕ້ອງໃຊ້ການຢືນຢັນຕົວຕົນດ້ວຍສະມາດກາດ ຫຼື ລາຍນິ້ວມື."

#: data/org.gnome.login-screen.gschema.xml:41
#: data/org.gnome.login-screen.gschema.xml:51
msgid "Path to small image at top of user list"
msgstr "ເສັ້ນທາງໄປຫາຮູບຂະໜາດນ້ອຍທີ່ຢູ່ເທິງສຸດຂອງລາຍຊື່ຜູ້ໃຊ້"

#: data/org.gnome.login-screen.gschema.xml:44
msgid ""
"The login screen can optionally show a small image to provide site "
"administrators and distributions a way to display branding."
msgstr "ໜ້າຈໍລັອກອິນສາມາດເລືອກທີ່ຈະສະແດງຮູບຂະໜາດນ້ອຍ ເພື່ອໃຫ້ຜູ້ເບິ່ງແຍງລະບົບ ແລະ ຜູ້ຈຳໜ່າຍ ສາມາດສະແດງຍີ່ຫໍ້ຂອງຕົນໄດ້."

#: data/org.gnome.login-screen.gschema.xml:54
msgid ""
"The fallback login screen can optionally show a small image to provide site "
"administrators and distributions a way to display branding."
msgstr "ໜ້າຈໍລັອກອິນສຳຮອງສາມາດເລືອກທີ່ຈະສະແດງຮູບຂະໜາດນ້ອຍ ເພື່ອໃຫ້ຜູ້ເບິ່ງແຍງລະບົບ ແລະ ຜູ້ຈຳໜ່າຍ ສາມາດສະແດງຍີ່ຫໍ້ຂອງຕົນໄດ້."

#: data/org.gnome.login-screen.gschema.xml:61
msgid "Avoid showing user list"
msgstr "ຫຼີກລ່ຽງການສະແດງລາຍຊື່ຜູ້ໃຊ້"

#: data/org.gnome.login-screen.gschema.xml:64
msgid ""
"The login screen normally shows a list of available users to log in as. This "
"setting can be toggled to disable showing the user list."
msgstr "ໂດຍປົກກະຕິ, ໜ້າຈໍລັອກອິນຈະສະແດງລາຍຊື່ຜູ້ໃຊ້ທີ່ສາມາດລັອກອິນໄດ້. ການຕັ້ງຄ່ານີ້ສາມາດເປີດ-ປິດ ເພື່ອປິດການສະແດງລາຍຊື່ຜູ້ໃຊ້."

#: data/org.gnome.login-screen.gschema.xml:71
msgid "Enable showing the banner message"
msgstr "ເປີດໃຊ້ການສະແດງຂໍ້ຄວາມປ້າຍປະກາດ"

#: data/org.gnome.login-screen.gschema.xml:74
msgid "Set to true to show the banner message text."
msgstr "ຕັ້ງເປັນ true ເພື່ອສະແດງຂໍ້ຄວາມປ້າຍປະກາດ."

#: data/org.gnome.login-screen.gschema.xml:80
msgid "Banner message source"
msgstr "ແຫຼ່ງທີ່ມາຂອງຂໍ້ຄວາມປ້າຍປະກາດ"

#: data/org.gnome.login-screen.gschema.xml:83
msgid "The source of the text banner message on the login screen."
msgstr "ແຫຼ່ງທີ່ມາຂອງຂໍ້ຄວາມປ້າຍປະກາດເທິງໜ້າຈໍລັອກອິນ."

#: data/org.gnome.login-screen.gschema.xml:89
msgid "Banner message text"
msgstr "ຂໍ້ຄວາມປ້າຍປະກາດ"

#: data/org.gnome.login-screen.gschema.xml:92
msgid "Text banner message to show in the login window."
msgstr "ຂໍ້ຄວາມປ້າຍປະກາດທີ່ຈະສະແດງໃນໜ້າຕ່າງລັອກອິນ."

#: data/org.gnome.login-screen.gschema.xml:98
msgid "Banner message path"
msgstr "ເສັ້ນທາງຂອງຂໍ້ຄວາມປ້າຍປະກາດ"

#: data/org.gnome.login-screen.gschema.xml:101
msgid "Path to text file with banner message to show in the login window."
msgstr "ເສັ້ນທາງໄປຫາໄຟລ໌ຂໍ້ຄວາມທີ່ມີຂໍ້ຄວາມປ້າຍປະກາດທີ່ຈະສະແດງໃນໜ້າຕ່າງລັອກອິນ."

#: data/org.gnome.login-screen.gschema.xml:107
msgid "Disable showing the restart buttons"
msgstr "ປິດການສະແດງປຸ່ມຣີສະຕາດ"

#: data/org.gnome.login-screen.gschema.xml:110
msgid "Set to true to disable showing the restart buttons in the login window."
msgstr "ຕັ້ງເປັນ true ເພື່ອປິດການສະແດງປຸ່ມຣີສະຕາດໃນໜ້າຕ່າງລັອກອິນ."

#: data/org.gnome.login-screen.gschema.xml:116
msgid "Number of allowed authentication failures"
msgstr "ຈຳນວນຄັ້ງທີ່ອະນຸຍາດໃຫ້ຢືນຢັນຕົວຕົນລົ້ມເຫຼວ"

#: data/org.gnome.login-screen.gschema.xml:119
msgid ""
"The number of times a user is allowed to attempt authentication, before "
"giving up and going back to user selection."
msgstr "ຈຳນວນຄັ້ງທີ່ຜູ້ໃຊ້ໄດ້ຮັບອະນຸຍາດໃຫ້ພະຍາຍາມຢືນຢັນຕົວຕົນ, ກ່ອນທີ່ຈະຍອມແພ້ ແລະ ກັບໄປໜ້າເລືອກຜູ້ໃຊ້."

#: utils/gdm-config.c:117
msgid "Show command help"
msgstr "ສະແດງຄຳແນະນຳຄຳສັ່ງ"

#: utils/gdm-config.c:121

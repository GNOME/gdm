#: utils/gdm-config.c:773
#, c-format
msgid "Failed to create directory %s"
msgstr "Ny yllir gwruthyl restrenva %s"

#: utils/gdm-config.c:844
msgid "dconf profile not found"
msgstr "profil dconf nyns o kevys"

#: utils/gdm-config.c:934
msgid "dconf has no system-db configured"
msgstr "nyns eus system-db selys dhe dconf"

#. TRANSLATORS: First value is a file path, second is an error message
#: utils/gdm-config.c:1083
#, c-format
msgid "Failed to get the “%s” header comment: %s, was it modified?"
msgstr "Ny yllir kerghes an kampol penn “%s”: %s, o yth chanjys?"

#: utils/gdm-config.c:1086
#, c-format
msgid "File “%s” header comment does not match, was it modified?"
msgstr "Kampol penn restren “%s” ny omdhesedha, o yth chanjys?"

#. XXX: Fail with an error instead?
#: utils/gdm-config.c:1214
#, c-format
msgid "No expected header found on lock file “%s”, was it modified?"
msgstr "Nyns eus penn gwaytys kevys war restren floren “%s”, o yth chanjys?"

#: utils/gdm-config.c:1499
msgid "Failed to run a required distro hook: "
msgstr "Ny yllir eksekutya higen lesrannans a res:"

#: utils/gdm-config.c:1515
msgid "COMMAND"
msgstr "ARGHADOW"

#: utils/gdm-config.c:1519
#, c-format
msgid ""
"Commands:\n"
"  help         Shows this information\n"
"  password     Configure the password authentication\n"
"  fingerprint  Configure the fingerprint authentication\n"
"  smartcard    Configure the smartcard authentication\n"
"  reset        Resets the default configuration\n"
"  show         Shows the current configuration\n"
"\n"
"Use “%s COMMAND --help” to get help on each command.\n"
msgstr ""
"Arghadowyow:\n"
"  help         Diskwedhes an kedhlow ma\n"
"  password     Selya an omgelmyans ger-tremena\n"
"  fingerprint  Selya an omgelmyans bys-prynt\n"
"  smartcard    Selya an omgelmyans karten gonnyk\n"
"  reset        Dasgorra an selyans defowt\n"
"  show         Diskwedhes an selyans a-lemmyn\n"
"\n"
"Devnydhyewgh “%s ARGHADOW --help” rag kavos gweres war bub arghadow.\n"

#: utils/gdm-config.c:1581
msgid "Command options"
msgstr "Dewisyow arghadow"

#. TRANSLATORS: You need to be root to use PROGRAM-NAME “command” command
#: utils/gdm-config.c:1616
#, c-format
msgid "You need to be root to use %s “%s” command"
msgstr "Res yw dhywgh bos gwreydhen rag devnydhya arghadow %s “%s”"


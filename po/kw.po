#, c-format
msgid "Failed to set %s setting: "
msgstr "Ny yllir gorra settyans %s:"

#: utils/gdm-config.c:1758
msgid "Failed to set smartcard setting"
msgstr "Ny yllir gorra settyans karten gonnyk"

#: utils/gdm-config.c:1764
msgid "Failed to set password setting"
msgstr "Ny yllir gorra settyans ger-tremena"

#: utils/gdm-config.c:1778
msgid "Enabled"
msgstr "Byw"

#: utils/gdm-config.c:1778
msgid "Disabled"
msgstr "Marow"

#: utils/gdm-config.c:1787
msgid "Not supported"
msgstr "Anskoodhys"

#: utils/gdm-config.c:1803
msgid "Required"
msgstr "A Res"

#: utils/gdm-config.c:1855
#, c-format
msgid ""
"GDM Authorization configuration\n"
"\n"
"  Password authentication: %s\n"
"  Fingerprint authentication: %s\n"
"  Smart Card authentication: %s\n"
"  Smart Card removal action: %s\n"
msgstr ""
"Selyans Omgelmyans GDM\n"
"\n"
"  Omgelmyans ger-tremena: %s\n"
"  Omgelmyans bys-prynt: %s\n"
"  Omgelmyans karten gonnyk: %s\n"
"  Gwrians ow remova karten gonnyk: %s\n"


msgstr "Nyns eus oberadowyow ewn kevys dhe eksekutya higen “%s”"

#: utils/gdm-config.c:656
#, c-format
msgid "Running distro hook “%s”\n"
msgstr "Owth eksekutya higen lesrannans “%s”\n"

#: utils/gdm-config.c:670
#, c-format
msgid "Distro hook “%s” requested stopping"
msgstr "Higen lesrannans “%s” govynys owth astel"

#: utils/gdm-config.c:683
#, c-format

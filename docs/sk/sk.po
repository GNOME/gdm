#, no-wrap
msgid ""
"\n"
"gdm: .evil.domain\n"
msgstr ""
"\n"
"gdm: .zakerna.domena\n"

#. (itstool) path: sect2/para
#: C/index.docbook:810
msgid "to <filename>&lt;etc&gt;/hosts.deny</filename>. You may also need to add"
msgstr ""
"do <filename>&lt;etc&gt;/hosts.deny</filename>. Možno budete musieť pridať aj"

#. (itstool) path: sect2/screen
#: C/index.docbook:814
#, no-wrap
msgid ""
"\n"
"gdm: .your.domain\n"
msgstr ""
"\n"
"gdm: .vasa.domena\n"
